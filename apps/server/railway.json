{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "buildCommand": "npm run build:shared && npm run build -w @acuo/server"
  },
  "deploy": {
    "startCommand": "npm run start -w @acuo/server",
    "healthcheckPath": "/api/health",
    "restartPolicyType": "ON_FAILURE"
  }
}
